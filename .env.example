# AI Generation (Gemini)
# Required for the /api/generate endpoint
GEMINI_API_KEY=your_gemini_api_key_here

# Image Search (Pexels)
# Required for the /api/pexels image search endpoint
PEXELS_API_KEY=your_pexels_api_key_here

# One-Click Deploy (Vercel)
# Required for the /api/deploy endpoint
VERCEL_DEPLOY_TOKEN=your_vercel_deploy_token_here
VERCEL_TEAM_ID=your_vercel_team_id_here

# Deploy Security
# Secret key to authorize deploy requests
OPENPAGE_DEPLOY_KEY=
# Comma-separated list of allowed CORS origins
OPENPAGE_ALLOWED_ORIGINS=https://web-designs.online
